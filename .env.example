# ============================================================================
#  CRM — Environment Variables
#  Copy each line into Vercel → Project → Settings → Environment Variables.
#  NOTHING is hardcoded in the source anymore — the app reads everything here.
#  Leave a channel's vars blank if you're not using that channel.
# ============================================================================

# ── Dashboard login (required) ──────────────────────────────────────────────
# DASHBOARD_PASSWORD: the password staff type to log into the dashboard.
# DASHBOARD_SECRET:   a long random string used to sign login sessions.
#                     Generate one, e.g.:  openssl rand -hex 32
DASHBOARD_PASSWORD=
DASHBOARD_SECRET=
# Optional: lock the dashboard API to your domain (recommended in production)
DASHBOARD_ORIGIN=https://your-app.vercel.app

# ── Database — Supabase (required) ──────────────────────────────────────────
# From Supabase → Project Settings → API.  Use the SERVICE ROLE key (server-side only).
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── AI brain ────────────────────────────────────────────────────────────────
# GROQ_API_KEY  — powers Instagram + Messenger replies (free tier).  console.groq.com
# OPENAI_API_KEY — powers WhatsApp replies + image/voice understanding.
# Set whichever channels you actually use.
GROQ_API_KEY=
OPENAI_API_KEY=

# ── WhatsApp (Meta Cloud API) ───────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=        # the verify token you type into the Meta webhook screen
META_APP_SECRET=             # Meta app → Settings → Basic → App Secret
META_WHATSAPP_TOKEN=         # WhatsApp permanent/system-user access token
META_PHONE_NUMBER_ID=        # WhatsApp phone number ID

# ── Instagram DMs (Instagram API with Instagram Login) ──────────────────────
# Each falls back to the WhatsApp/Meta value above if left blank, so a single
# Meta app can serve all channels — or set these to run IG on its own app.
IG_VERIFY_TOKEN=
IG_APP_SECRET=
IG_PAGE_TOKEN=               # Instagram access token (IGAA…). Use a LONG-LIVED token.
IG_PAGE_ID=                  # optional — IG business account id (ignores echoes)

# ── Facebook Messenger ──────────────────────────────────────────────────────
FB_VERIFY_TOKEN=
FB_APP_SECRET=
FB_PAGE_TOKEN=               # Facebook Page access token (EAA…). Use a LONG-LIVED/system-user token.
FB_PAGE_ID=                  # optional — Page id (ignores echoes)

# ── POS integration (optional) ──────────────────────────────────────────────
POS_API_SECRET=

# ============================================================================
#  ROBUSTNESS NOTES (so it "lasts forever")
#  • Use LONG-LIVED or System-User tokens for IG_PAGE_TOKEN / FB_PAGE_TOKEN /
#    META_WHATSAPP_TOKEN. Short-lived tokens expire in ~1 hour and the bot goes
#    quiet — that was the #1 cause of breakage. System-user tokens don't expire.
#  • Every webhook FAILS CLOSED: if a secret/token is missing, it rejects rather
#    than misbehaving. So a missing var = clear error, never silent corruption.
#  • Vercel Hobby plan allows max 12 serverless functions. This repo uses 11.
#    If you add more, either consolidate routes or upgrade the Vercel plan.
#  • Never commit real values — keep them only in Vercel's env settings.
# ============================================================================
