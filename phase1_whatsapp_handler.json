            }
          }
        }
      },
      "continueOnFail": true
    },
    {
      "id": "node-get-history",
      "name": "Get Conversation History",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1140, 300],
      "parameters": {
