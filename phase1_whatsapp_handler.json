        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "customer_id", "value": "=eq.{{ $json[0].id }}" },
            { "name": "order", "value": "timestamp.desc" },
            { "name": "limit", "value": "5" },
            { "name": "select", "value": "direction,message,intent,timestamp" }
          ]
        },
        "options": {}
      },
      "continueOnFail": true
    },
    {
      "id": "node-ai-detect",
      "name": "AI Intent Detection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1380, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{ $env.GROQ_API_KEY }}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.4,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a friendly, warm restaurant assistant for Tilapiya Restaurant in Sri Lanka. Currency is LKR.\\n\\nRestaurant info:\\n- Open: Tuesday-Sunday, 11:30 AM - 10:30 PM. Closed Mondays.\\n- Location: Colombo 7, Sri Lanka\\n- Cuisine: Modern Sri Lankan, seafood specialties\\n- Parking: Free valet parking available\\n- Special diets: Vegetarian, vegan, gluten-free options available\\n\\nYour job:\\n1. Detect the customer intent from their message.\\n2. For BOOKING: extract date, time, party_size, occasion, dietary_notes if mentioned.\\n3. For INQUIRY: answer from the restaurant info above.\\n4. For COMPLAINT: be empathetic, apologize, assure follow-up.\\n5. For CANCEL: confirm which booking to cancel.\\n6. For OTHER: be helpful and friendly.\\n\\nAlways reply in a warm, professional tone. Keep replies concise (under 200 words). Use emoji sparingly.\\n\\nReturn ONLY valid JSON:\\n{\\n  \\\"intent\\\": \\\"BOOKING\\\" | \\\"INQUIRY\\\" | \\\"COMPLAINT\\\" | \\\"CANCEL\\\" | \\\"OTHER\\\",\\n  \\\"reply\\\": \\\"your natural language reply to the customer\\\",\\n  \\\"booking_details\\\": {\\n    \\\"date\\\": \\\"YYYY-MM-DD or null\\\",\\n    \\\"time\\\": \\\"HH:MM or null\\\",\\n    \\\"party_size\\\": number or null,\\n    \\\"occasion\\\": \\\"string or null\\\",\\n    \\\"dietary_notes\\\": \\\"string or null\\\"\\n  },\\n  \\\"is_booking_complete\\\": true/false\\n}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Customer name: {{ $('Extract Message Data').item.json.name }}\\nCustomer message: {{ $('Extract Message Data').item.json.text }}\\n\\nRecent conversation history:\\n{{ JSON.stringify($('Get Conversation History').first().json) }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "continueOnFail": true
    },
    {
      "id": "node-parse-ai",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1620, 300],
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json;\nconst customerData = $('Upsert Customer').first().json;\nconst messageData = $('Extract Message Data').first().json;\n\nlet parsed;\ntry {\n  const content = aiResponse.choices[0].message.content;\n  parsed = JSON.parse(content);\n} catch (e) {\n  parsed = {\n    intent: 'OTHER',\n    reply: 'Thank you for your message! Let me get back to you shortly.',\n    booking_details: { date: null, time: null, party_size: null, occasion: null, dietary_notes: null },\n    is_booking_complete: false\n  };\n}\n\nreturn [{\n  json: {\n    phone: messageData.phone,\n    name: messageData.name,\n    text: messageData.text,\n    timestamp: messageData.timestamp,\n    customer_id: Array.isArray(customerData) ? customerData[0]?.id : customerData?.id,\n    intent: parsed.intent,\n    reply: parsed.reply,\n    booking_details: parsed.booking_details,\n    is_booking_complete: parsed.is_booking_complete\n  }\n}];\n"
      }
    },
