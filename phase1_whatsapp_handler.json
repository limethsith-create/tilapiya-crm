            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "resolution=merge-duplicates,return=representation" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"phone\": \"{{ $('Extract Message Data').item.json.phone }}\",\n  \"name\": \"{{ $('Extract Message Data').item.json.name }}\",\n  \"last_contact\": \"{{ $('Extract Message Data').item.json.timestamp }}\"\n}",
        "options": {
