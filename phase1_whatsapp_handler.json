{
  "name": "Phase 1 â WhatsApp Incoming Handler",
  "nodes": [
    {
      "id": "node-webhook",
      "name": "WhatsApp Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "parameters": {
        "path": "whatsapp",
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "options": {}
      }
    },
    {
      "id": "node-respond",
      "name": "Respond 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [440, 140],
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK",
        "options": {
          "responseCode": 200
        }
      }
    },
    {
      "id": "node-extract",
      "name": "Extract Message Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [440, 380],
      "parameters": {
        "jsCode": "// Extract message from WhatsApp Cloud API webhook payload\nconst body = $input.first().json.body ?? $input.first().json;\nconst entry = body?.entry?.[0];\nconst change = entry?.changes?.[0];\nconst message = change?.value?.messages?.[0];\nconst contact = change?.value?.contacts?.[0];\n\n// Skip non-text messages and status updates\nif (!message || message.type !== 'text') {\n  return [{ json: { skip: true } }];\n}\n\nconst phone = message.from;\nconst name = contact?.profile?.name ?? 'Customer';\nconst text = (message.text?.body ?? '').trim();\nconst timestamp = new Date(parseInt(message.timestamp) * 1000).toISOString();\n\nreturn [{ json: { phone, name, text, timestamp, skip: false } }];\n"
      }
    },
    {
      "id": "node-skip-check",
      "name": "Skip Non-Text?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [660, 380],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-skip",
              "leftValue": "={{ $json.skip }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ]
        }
      }
    },
    {
      "id": "node-upsert-customer",
      "name": "Upsert Customer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [900, 300],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.SUPABASE_URL }}/rest/v1/customers",
        "authentication": "genericCredentialType",
