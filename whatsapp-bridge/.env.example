# ===== Tilapiya CRM — WhatsApp Web bridge config =====
# Copy this file to .env and fill the values in.

# 1) Where the brain lives (the Vercel-deployed endpoint).
#    Defaults to https://tilapiya-crm2.vercel.app/api/wa-bridge — only change
#    if your Vercel project has a different URL.
BRAIN_URL=https://tilapiya-crm2.vercel.app/api/wa-bridge

# 2) Shared secret. Must match the BRIDGE_SECRET env var on Vercel.
#    The default below works out of the box (the brain has the same default
#    baked in). For production, replace BOTH sides with a fresh random string.
BRIDGE_SECRET=0ed3044a61fc16eb2d599bae52f3d75849987e768520dd72

# 3) The WhatsApp number you're linking — digits only, no plus, no spaces.
#    e.g. 94771234567 for Sri Lanka 077 123 4567.
#    Leave blank to fall back to QR-code pairing.
PAIR_NUMBER=

# 4) Should the bot reply inside group chats?  true / false  (default false)
REPLY_TO_GROUPS=false

# 5) HTTP timeout when talking to the brain (milliseconds, default 25000)
REQUEST_TIMEOUT_MS=25000
